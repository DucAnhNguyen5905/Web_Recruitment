@model RecruitmentWebFE.Models.CreatePostViewModel
@{
    ViewData["Title"] = "Tạo bài đăng mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Tạo bài đăng mới</h1>
            </div>
            <div class="col-sm-6 text-end">
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="card shadow-sm">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="JobTitle" class="form-label fw-semibold">Tiêu đề công việc</label>
                        <input asp-for="JobTitle" class="form-control" />
                        <span asp-validation-for="JobTitle" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="JobDescription" class="form-label fw-semibold">Mô tả công việc</label>
                        <textarea asp-for="JobDescription" id="JobDescription" class="form-control" rows="8"></textarea>
                        <span asp-validation-for="JobDescription" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="JobRequirements" class="form-label fw-semibold">Yêu cầu công việc</label>
                        <textarea asp-for="JobRequirements" id="JobRequirements" class="form-control" rows="8"></textarea>
                        <span asp-validation-for="JobRequirements" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SalaryMin" class="form-label fw-semibold">Lương tối thiểu</label>
                            <input asp-for="SalaryMin" type="number" class="form-control" />
                            <span asp-validation-for="SalaryMin" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SalaryMax" class="form-label fw-semibold">Lương tối đa</label>
                            <input asp-for="SalaryMax" type="number" class="form-control" />
                            <span asp-validation-for="SalaryMax" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactType" class="form-label fw-semibold">Loại liên hệ</label>
                        <select asp-for="ContactType" asp-items="Model.ContactTypeOptions" class="form-select">
                            <option value="">-- Chọn loại liên hệ --</option>
                        </select>
                        <span asp-validation-for="ContactType" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="JobPositionId" class="form-label fw-semibold">Vị trí công việc</label>
                            <select asp-for="JobPositionId" asp-items="Model.JobPositionOptions" class="form-select">
                                <option value="">-- Chọn vị trí --</option>
                            </select>
                            <span asp-validation-for="JobPositionId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="JobTypeId" class="form-label fw-semibold">Loại công việc</label>
                            <select asp-for="JobTypeId" asp-items="Model.JobTypeOptions" class="form-select">
                                <option value="">-- Chọn loại công việc --</option>
                            </select>
                            <span asp-validation-for="JobTypeId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="JobCategoryId" class="form-label fw-semibold">Danh mục công việc</label>
                            <select asp-for="JobCategoryId" asp-items="Model.JobCategoryOptions" class="form-select">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="JobCategoryId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CVLanguageId" class="form-label fw-semibold">Ngôn ngữ CV</label>
                            <select asp-for="CVLanguageId" asp-items="Model.CVLanguageOptions" class="form-select">
                                <option value="">-- Chọn ngôn ngữ CV --</option>
                            </select>
                            <span asp-validation-for="CVLanguageId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ExpiryDate" class="form-label fw-semibold">Ngày hết hạn</label>
                            <input asp-for="ExpiryDate" type="date" class="form-control" />
                            <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="OfficeText" class="form-label fw-semibold">Văn phòng áp dụng</label>
                            <textarea asp-for="OfficeText" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="OfficeText" class="text-danger"></span>
                            <div class="form-text">ngăn cách bằng dấu phẩy/ xuống dòng.</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="KeywordText" class="form-label fw-semibold">Keyword công việc</label>
                            <textarea asp-for="KeywordText" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="KeywordText" class="text-danger"></span>
                            <div class="form-text">ngăn cách bằng dấu phẩy/ xuống dòng.</div>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light border">Hủy</a>
                    <button type="submit" class="btn btn-primary">Lưu bài đăng</button>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        if (document.getElementById('JobDescription') && !CKEDITOR.instances['JobDescription']) {
            CKEDITOR.replace('JobDescription');
        }

        if (document.getElementById('JobRequirements') && !CKEDITOR.instances['JobRequirements']) {
            CKEDITOR.replace('JobRequirements');
        }
    </script>
}

