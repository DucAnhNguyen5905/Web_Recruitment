@model List<RecruitmentWebFE.Models.PostViewsModel>

@{
    ViewData["Title"] = "Danh sách bài đăng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Danh sách bài đăng</h2>
        <a asp-controller="Post" asp-action="Create" class="btn btn-success">Tạo bài đăng mới</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Bạn chưa có bài đăng nào.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Tiêu đề</th>
                    <th>Địa điểm</th>
                    <th>Lương</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th style="width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model)
                {
                    <tr class="align-middle">
                                  <td>@post.Post_ID</td>
                                  <td>@post.Job_Title</td>
                                  <td>
                                    <div class="progress progress-xs">
                                      <div class="progress-bar progress-bar-danger" style="width: 55%"></div>
                                    </div>
                                  </td>
                                  <td> <a asp-action="Edit" asp-route-id="@post.Post_ID" class="btn btn-warning">Sửa</a></td>
                                </tr>
                   
                }
            </tbody>
        </table>
    }
</div>